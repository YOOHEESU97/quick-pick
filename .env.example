# 동행복권 계정 (예치금 미리 충전 필요)
DHLOTTERY_ID=your_id
DHLOTTERY_PASSWORD=your_password

# OpenAI API (선택 — 없으면 통계 기반 추천)
OPENAI_API_KEY=sk-...

# 구매 설정
# 구매 게임 수 (1~5, 동행복권 온라인 주당 최대 5)
TICKET_COUNT=5
HISTORY_WEEKS=52
# 매주 월요일 10:00 (KST) — node-cron: 0=일, 1=월, …, 6=토
CRON_SCHEDULE=0 10 * * 1

# 캐시 파일 경로 (선택)
# CACHE_PATH=data/draws.json

# HTTP 타임아웃/재시도 (동행복권 서버가 느릴 때)
HTTP_TIMEOUT_MS=90000
HTTP_RETRY_COUNT=2

# 당첨 API 호출 간격(ms) · 캐시 유효 시간(시간)
API_MIN_DELAY_MS=2000
# el.dhlottery 연금 구매 API 간격(ms) — checkVerifyNo/makeOrderNo/connPro 등
PENSION_API_MIN_DELAY_MS=10000
# connPro '구매 진행중' 오류 시 자동 재시도 대기(ms)
PENSION_PENDING_RETRY_WAIT_MS=60000
# 매진 번호 재확인 최대 횟수 (checkVerifyNo, 기본 5)
PENSION_VERIFY_MAX_ATTEMPTS=5
# API 형식 오류 N회 연속 시 buy/pension-buy 자동 중지 (기본 3)
API_CIRCUIT_FAIL_THRESHOLD=3
# 서킷 OPEN 후 구매 재허용 대기(ms) — 기본 1시간
API_CIRCUIT_COOLDOWN_MS=3600000
CACHE_MAX_AGE_HOURS=12

# 연금복권720+
PENSION_TICKET_COUNT=1
PENSION_HISTORY_WEEKS=52
PENSION_CRON_SCHEDULE=0 10 * * 3

# Supabase (로그·구매 기록) — Project Settings → API
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (Secret / service_role, 서버 전용)
# STORAGE_BACKEND=auto   # 로그·구매: auto | local | supabase | both
# DRAWS_STORAGE=both     # 당첨 회차: auto | local | supabase | both (VM이면 both 권장)

# buy 성공 시 저장 (대시보드 예치금 표시용, API 재조회 없음)
# ACCOUNT_SNAPSHOT_PATH=data/account-snapshot.json

# 대시보드 (npm run web)
DASHBOARD_PORT=3847
DASHBOARD_HOST=127.0.0.1
# Oracle VM에서 외부 접속 시: DASHBOARD_HOST=0.0.0.0 + Security List 3847 포트 개방

# AI 모델 (선택)
OPENAI_MODEL=gpt-4o-mini
